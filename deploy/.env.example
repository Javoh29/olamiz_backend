# Контракт окружения Olamiz backend (docs/backend.md §9).
# Скопировать в deploy/.env и заполнить секреты. Секреты в репозиторий не коммитить.

# --- Приложение ---
DEBUG=false
BASE_URL=https://olamiz.uz
DISPLAY_TIMEZONE=Asia/Tashkent

# --- Postgres (контейнер) ---
POSTGRES_USER=olamiz
POSTGRES_PASSWORD=olamiz
POSTGRES_DB=olamiz

# --- Инфраструктура (внутри compose переопределяются на имена сервисов) ---
DATABASE_URL=postgresql+asyncpg://olamiz:olamiz@localhost:5432/olamiz
REDIS_URL=redis://localhost:6379/0

# --- Auth: JWT + OTP ---
JWT_SECRET=change-me-in-production-use-32-bytes-or-more
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30
OTP_TTL_MIN=5
OTP_RATE_PER_PHONE_HOUR=3
OTP_RATE_PER_IP_HOUR=10

# --- Тайминги сделки и эскалаций ---
ESCALATE_SMS_MIN=3
ESCALATE_CALL_MIN=7
ALTERNATIVES_MIN=15
BOOKING_EXPIRE_H=24
AUTO_COMPLETE_DAYS=3
REVIEW_BLIND_DAYS=7
MAX_RENT_DAYS=30

# --- Веса ранжирования каталога (architecture.md §7) ---
RANK_W1=0.3
RANK_W2=0.3
RANK_W3=0.2
RANK_W4=0.2

# --- SMS-провайдер: eskiz | playmobile ---
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
PLAYMOBILE_LOGIN=
PLAYMOBILE_PASSWORD=

# --- S3 / MinIO (фото; хранение только на серверах в УЗ) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=olamiz

# --- Наблюдаемость ---
SENTRY_DSN=

# --- Telegram-бот прокатчика (бренд Beramiz, @beramiz_bot) ---
TG_BOT_TOKEN=
TG_WEBHOOK_SECRET=
